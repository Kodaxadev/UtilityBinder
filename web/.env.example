# UtilityBinder — environment variables
# Copy to .env.local for local dev; set in Vercel project settings for deploys.

# Where intake form submissions are forwarded (Zapier / Make / Supabase function —
# anything that accepts a JSON POST). REQUIRED in production: without it,
# submissions are only visible in server logs. See app/api/intake/route.ts.
INTAKE_WEBHOOK_URL=
