# UtilityBinder — environment variables
# Copy to .env.local for local dev; set in Vercel project settings for deploys.

# Where intake form submissions are forwarded (Zapier / Make / Supabase function —
# anything that accepts a JSON POST). REQUIRED in production: the API returns
# 503 without it so leads are never silently dropped. See app/api/intake/route.ts.
INTAKE_WEBHOOK_URL=

# Shown to visitors as the email fallback when the form fails (optional but
# strongly recommended before outreach). Public — use a business address.
NEXT_PUBLIC_CONTACT_EMAIL=
